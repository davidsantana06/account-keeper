{% from macro('banner_header') import banner_header %}
{% from macro('form_action') import form_action %}
{% from macro('form_field') import form_field %}
{% from macro('right_tag') import right_tag %}

{% extends layout ('base') %}

{% block content %}
    {{ banner_header(image=static('img:b-template.png')) }}
    <main class="container is-max-tablet px-5 mb-5">
        <form
            data-action="{{ view('user:put') }}"
            data-method="put"
        >
            <div class="box p-5 mb-5">
                {{ right_tag('Informações básicas') }}
                {{ form_field(form.name) }}
            </div>
            <div class="box p-5 mb-5">
                {{ right_tag('Preferências') }}
                {{ form_field(
                    form.zoom,
                    encapsulation='select',
                    widget='select',
                )}}
            </div>
            {{ form_action(
                form.submit,
                back_href=view('user:index')
            ) }}
        </form>
    </main>
{% endblock %}