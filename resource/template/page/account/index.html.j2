{% extends layout('base') %}

{% block content %}
    <main class="container px-5 mt-5 mb-4">
        {% for row in accounts | batch(2) %}
            <div class="columns">
                {% for account in row %}
                    <div class="column is-full is-6">
                        <div
                            class="card is-clickable"
                            data-href="{{ view('account:update', id=account.id) }}"
                        >
                            <div class="card-content is-flex is-align-items-center">
                                <figure class="image is-64x64 is-flex-shrink-0 mr-5">
                                    <img
                                        class="is-rounded"
                                        src="{{ static('img:i-template.png') }}"
                                    />
                                </figure>
                                <div>
                                    <h2 class="title is-6 mb-1">
                                        {{ account.name | truncate(27, killwords=True) }}
                                    </h2>
                                    <span class="subtitle is-7">
                                        {{
                                            account.username or
                                            account.email | truncate(47, killwords=True) or
                                            account.phone or
                                            'Sem credenciais'
                                        }}
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endfor %}
        <a
            class="
                button
                is-primary
                is-rounded
                is-position-fixed
                is-right-0
                is-bottom-0
                has-text-weight-semibold
                px-5
                mr-5
                mb-5
            "
            href="{{ view('account:create') }}"
        >
            + Adicionar
        </a>
    </main>
{% endblock %}